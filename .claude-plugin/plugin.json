{
  "name": "onchain-alpha-radar",
  "version": "1.0.0",
  "description": "On-chain alpha discovery and research pipeline. Token Discovery → Holdings Analysis → Smart Money Tracking → Research Report.",
  "author": "chain-data",
  "skills": ["./skills/"],
  "keywords": [
    "skills",
    "onchain",
    "alpha",
    "smart-money",
    "whale",
    "token",
    "research",
    "blockchain",
    "defi",
    "meme",
    "dex",
    "web3",
    "holdings",
    "portfolio",
    "research-report"
  ],
  "dependencies": {
    "onchainos-skills": {
      "source": "okx/onchainos-skills",
      "type": "cli-binary",
      "required": true,
      "install": "curl -sSL https://raw.githubusercontent.com/okx/onchainos-skills/main/install.sh | sh"
    },
    "opentwitter-mcp": {
      "source": "6551Team/opentwitter-mcp",
      "type": "mcp-server",
      "required": false,
      "install": "claude mcp add twitter -e TWITTER_TOKEN=<your-token> -- uv --directory /path/to/opentwitter-mcp run opentwitter-mcp"
    },
    "deep-research": {
      "source": "wshuyi/deep-research",
      "type": "skill",
      "required": false,
      "install": "git clone https://github.com/wshuyi/deep-research.git && cp -r deep-research/skills/deep-research ~/.claude/skills/"
    },
    "excalidraw-diagram": {
      "source": "coleam00/excalidraw-diagram-skill",
      "type": "skill",
      "required": false,
      "install": "git clone https://github.com/coleam00/excalidraw-diagram-skill.git && cp -r excalidraw-diagram-skill .claude/skills/excalidraw-diagram"
    }
  }
}